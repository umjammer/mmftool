/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDI_MAIN                ICON    DISCARDABLE     "main.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAIN MENU DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl-N",                ID_NEWSMAF
        MENUITEM "&Load SMAF\tCtrl-O",          ID_OPENSMAF
        MENUITEM "&Reload SMAF\tCtrl-R",        ID_RELOAD
        MENUITEM "&Reconvert SMAF(not implemented)", ID_RECONVERT, GRAYED
        MENUITEM "&Close\tCtrl-W",              ID_CLOSE
        MENUITEM "C&ompile SMAF to memory\tCtrl-M", ID_COMPILESMAF
        MENUITEM "&Save memory SMAF\tCtrl-S",   ID_SAVESMAF
        MENUITEM SEPARATOR
        MENUITEM "Save settings to &INI Now!",  ID_SAVESETTINGS
        MENUITEM SEPARATOR
        MENUITEM "&Exit\tAlt-X",                ID_EXIT
    END
    POPUP "&Music"
    BEGIN
        MENUITEM "&EmuPlay\tF5",                ID_PLAY
        MENUITEM "&MidiPlay\tF6",               ID_MIDIPLAY
        MENUITEM "&Stop\tF7",                   ID_STOP
        MENUITEM "&Rewind\tF8",                 ID_REWIND
        MENUITEM "M&idiReset\tF9",              ID_MIDIRESET
        MENUITEM SEPARATOR
        MENUITEM "&NiagaraTouch",               ID_TOGGLENIAGARA
        MENUITEM "Read&Only",                   ID_TOGGLERO
        MENUITEM "&Don't preview",              ID_TOGGLENP
    END
    POPUP "&View"
    BEGIN
        MENUITEM "Visible Track Only:",         0, INACTIVE
        MENUITEM SEPARATOR
        MENUITEM "Track1(Silver)\t&1",          ID_VTRACK1
        MENUITEM "Track2(Red)\t&2",             ID_VTRACK2
        MENUITEM "Track3(Green)\t&3",           ID_VTRACK3
        MENUITEM "Track4(Blue)\t&4",            ID_VTRACK4
        MENUITEM "Track5(Yellow)\t&5",          ID_VTRACK5
        MENUITEM "Track6(Cyan)\t&6",            ID_VTRACK6
        MENUITEM "Track7(Purple)\t&7",          ID_VTRACK7
        MENUITEM "Track8(White)\t&8",           ID_VTRACK8
        MENUITEM "All\t&0",                     ID_VTRACKALL, MENUBARBREAK
        MENUITEM SEPARATOR
        MENUITEM "Track9(Black)\t&Q",           ID_VTRACK9
        MENUITEM "Track10(DarkRed)\t&W",        ID_VTRACK10
        MENUITEM "Track11(DarkGreen)\t&E",      ID_VTRACK11
        MENUITEM "Track12(DarkBlue)\t&R",       ID_VTRACK12
        MENUITEM "Track13(DarkYellow)\t&T",     ID_VTRACK13
        MENUITEM "Track14(DarkCyan)\t&Y",       ID_VTRACK14
        MENUITEM "Track15(DarkPurple)\t&U",     ID_VTRACK15
        MENUITEM "Track16(Gray)\t&I",           ID_VTRACK16
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "&Show detail...",             ID_DETAILWND
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Index\tF1",                  ID_HELPINDEX
        MENUITEM SEPARATOR
        MENUITEM "&About...",                   ID_ABOUT
    END
END

IDR_EVENTITEM MENU DISCARDABLE 
BEGIN
    MENUITEM "insert &Before",              ID_EIINSERTBEFORE
    MENUITEM "insert &After",               ID_EIINSERTAFTER
    MENUITEM SEPARATOR
    MENUITEM "Set this event ""St&artItem""", ID_EISETSTART
    MENUITEM "Set this event ""St&opItem""", ID_EISETSTOP
    MENUITEM SEPARATOR
    MENUITEM "&Edit",                       ID_EIEDIT
    MENUITEM "&Delete",                     ID_EIDELETE
END

IDR_PIANOROLL MENU DISCARDABLE 
BEGIN
    MENUITEM "&Scroll to here",             ID_PRSCROLLTO
    MENUITEM "Play(&Emu) from here",        ID_PRPLAYEMUHERE
    MENUITEM "Play(&MIDI) from here",       ID_PRPLAYMIDIHERE
    MENUITEM "&View only this track",       ID_PRONLYTRACK
    MENUITEM SEPARATOR
    MENUITEM "Set this event ""St&artItem""", ID_PRSETSTART
    MENUITEM "Set this event ""St&opItem""", ID_PRSETSTOP
    MENUITEM SEPARATOR
    MENUITEM "&Delete",                     ID_PRDELETE
END


