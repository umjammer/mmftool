    VK_F8,          ID_REWIND,              VIRTKEY, NOINVERT
    VK_F9,          ID_MIDIRESET,           VIRTKEY, NOINVERT
    "W",            ID_CLOSE,               VIRTKEY, CONTROL, NOINVERT
    "X",            ID_EXIT,                VIRTKEY, ALT, NOINVERT
END


